{
  "manifest_version": 3,
  "name": "Tab Out",
  "version": "1.1.0",
  "description": "Keep tabs on your tabs. Group open tabs by domain and sleep eligible inactive tabs to free memory.",
  "permissions": ["tabs", "activeTab", "storage", "system.memory"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Out",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
